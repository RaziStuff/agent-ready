{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-ready.dev/schemas/impact.schema.json",
  "title": "agent-ready impact report",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "root",
    "status",
    "ok",
    "pathSource",
    "paths",
    "impacts",
    "affectedPackages",
    "recommendedCommands",
    "relevantDocs",
    "ci",
    "summary",
    "nextSteps"
  ],
  "properties": {
    "root": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "ok": {
      "type": "boolean"
    },
    "pathSource": {
      "type": "string",
      "enum": ["provided", "git_changed"]
    },
    "paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "impacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathImpact"
      }
    },
    "recommendedCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommendedCommand"
      }
    },
    "affectedPackages": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/affectedPackage"
      }
    },
    "relevantDocs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/pathRole"
      }
    },
    "ci": {
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/summary"
    },
    "nextSteps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["purpose", "packageManagers", "frameworks"],
      "properties": {
        "purpose": {
          "type": "string"
        },
        "primaryLanguage": {
          "type": ["string", "null"]
        },
        "packageManagers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "frameworks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "category", "severity", "reason"],
      "properties": {
        "path": {
          "type": "string"
        },
        "category": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "reason": {
          "type": "string"
        }
      }
    },
    "pathImpact": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "input",
        "path",
        "exists",
        "outsideRoot",
        "severity",
        "categories",
        "risks",
        "notes",
        "workspacePackages"
      ],
      "properties": {
        "input": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "outsideRoot": {
          "type": "boolean"
        },
        "severity": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "categories": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "risks": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/risk"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspacePackages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/workspacePackageRef"
          }
        }
      }
    },
    "recommendedCommand": {
      "type": "object",
      "additionalProperties": true,
      "required": ["name", "command", "reason", "risk", "requiresNetwork", "writesFiles"],
      "properties": {
        "name": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "risk": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "requiresNetwork": {
          "type": "boolean"
        },
        "writesFiles": {
          "type": "boolean"
        }
      }
    },
    "workspacePackageRef": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "name"],
      "properties": {
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        }
      }
    },
    "affectedPackage": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path", "name", "private", "scripts", "commands", "changedPaths"],
      "properties": {
        "path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "private": {
          "type": "boolean"
        },
        "scripts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "commands": {
          "type": "array"
        },
        "changedPaths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "pathRole": {
      "type": "object",
      "additionalProperties": true,
      "required": ["path"],
      "properties": {
        "path": {
          "type": "string"
        },
        "role": {
          "type": "string"
        }
      }
    }
  }
}
