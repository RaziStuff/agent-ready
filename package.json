{
  "name": "@ahmedshaikh/agent-ready",
  "version": "0.2.9",
  "description": "Generate AGENTS.md, repo metadata, and MCP context so AI coding agents can onboard quickly.",
  "type": "module",
  "bin": {
    "agent-ready": "src/cli/main.js"
  },
  "homepage": "https://github.com/RaziStuff/agent-ready#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RaziStuff/agent-ready.git"
  },
  "bugs": {
    "url": "https://github.com/RaziStuff/agent-ready/issues"
  },
  "scripts": {
    "scan": "node src/cli/main.js scan",
    "init": "node src/cli/main.js init",
    "context": "node src/cli/main.js context",
    "workspaces": "node src/cli/main.js workspaces",
    "affected": "node src/cli/main.js affected",
    "doctor": "node src/cli/main.js doctor",
    "doctor:strict": "node src/cli/main.js doctor --strict",
    "validate": "node src/cli/main.js validate",
    "validate:strict": "node src/cli/main.js validate --strict",
    "test": "node --test tests/*.test.js",
    "snapshots:check": "node scripts/snapshots.js --check",
    "snapshots:update": "node scripts/snapshots.js --write",
    "mcp:compat": "node scripts/mcp-compat-smoke.js",
    "package:check": "node scripts/package-smoke.js",
    "package:install-smoke": "node scripts/package-install-smoke.js",
    "published:smoke": "node scripts/published-package-smoke.js",
    "release:notes": "node scripts/release-notes.js",
    "release:notes:check": "node scripts/release-notes.js --check",
    "release:notes:write": "node scripts/release-notes.js --write",
    "ci": "npm test && npm run snapshots:check && npm run validate:strict && npm run doctor:strict && npm run mcp:compat && npm run package:check && npm run package:install-smoke && npm run release:notes:check"
  },
  "engines": {
    "node": ">=18.17"
  },
  "files": [
    "src",
    "schemas",
    "docs",
    "action.yml",
    "agent-ready.config.example.json",
    "AGENTS.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "RELEASE_NOTES.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agentic",
    "agents",
    "AGENTS.md",
    "ai",
    "ai-agents",
    "cli",
    "codex",
    "developer-tools",
    "mcp",
    "monorepo",
    "repo"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
