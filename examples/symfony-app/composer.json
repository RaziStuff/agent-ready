{
  "name": "acme/symfony-support-console",
  "type": "project",
  "description": "Reference Symfony application for support operations and moderation workflows.",
  "require": {
    "php": ">=8.3",
    "symfony/console": "^7.0",
    "symfony/framework-bundle": "^7.0",
    "symfony/runtime": "^7.0",
    "symfony/twig-bundle": "^7.0",
    "symfony/yaml": "^7.0"
  },
  "require-dev": {
    "friendsofphp/php-cs-fixer": "^3.0",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  }
}
