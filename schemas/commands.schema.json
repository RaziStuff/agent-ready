{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-ready.dev/schemas/commands.schema.json",
  "title": "agent-ready command catalog",
  "type": "object",
  "additionalProperties": true,
  "required": ["schemaVersion", "generatedAt", "commands"],
  "properties": {
    "schemaVersion": {
      "type": "string"
    },
    "generatedAt": {
      "type": "string"
    },
    "commands": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "name",
          "command",
          "source",
          "confidence",
          "requiresNetwork",
          "writesFiles",
          "risk"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          },
          "role": {
            "type": "string"
          },
          "executionMode": {
            "type": "string",
            "enum": ["one-shot", "long-running"]
          },
          "requiresNetwork": {
            "type": "boolean"
          },
          "writesFiles": {
            "type": "boolean"
          },
          "risk": {
            "type": "string",
            "enum": ["low", "medium", "high"]
          }
        }
      }
    }
  }
}
