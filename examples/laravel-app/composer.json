{
  "name": "acme/support-portal",
  "type": "project",
  "description": "Laravel application for support request intake, queueing, and account lookup.",
  "require": {
    "php": "^8.3",
    "laravel/framework": "^13.0",
    "laravel/tinker": "^3.0"
  },
  "require-dev": {
    "laravel/pint": "^1.27",
    "phpunit/phpunit": "^12.5"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": [
      "@php artisan test"
    ],
    "format": [
      "vendor/bin/pint"
    ]
  }
}
