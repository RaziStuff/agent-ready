{
  "name": "acme/pest-assertion-tools",
  "type": "library",
  "description": "Tiny Composer package for expressive Pest assertions and matcher helpers.",
  "require": {
    "php": "^8.3"
  },
  "require-dev": {
    "pestphp/pest": "^4.0",
    "phpstan/phpstan": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "Acme\\PestAssertionTools\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Acme\\PestAssertionTools\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "pest",
    "test:unit": "pest tests/Unit",
    "test:type:check": "phpstan analyse"
  }
}
